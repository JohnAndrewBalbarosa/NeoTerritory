# Server
PORT=3001
CORS_ORIGIN=http://localhost:3001

# Database (optional — defaults to Codebase/Backend/neoterritory.db)
# DB_PATH=/absolute/path/to/neoterritory.db

# Auth — long random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# If left unset or empty the backend autogenerates a one-shot secret on startup
# (with a warning) so first-clone developers don't hit "secretOrPrivateKey must
# have a value". Sessions then invalidate every restart. Always set explicitly
# in production.
JWT_SECRET=

# AI Documentation (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# C++ Pattern Microservice
NEOTERRITORY_BIN=/path/to/NeoTerritory/binary
NEOTERRITORY_CATALOG=/path/to/pattern_catalog.json

# Test output directory (optional — defaults to repo root /test)
# TEST_RESULTS_DIR=/absolute/path/to/test

# Seeds — TEST ONLY
# Set SEED_TEST_USERS=1 to seed 100 Devcon test accounts (Devcon1..Devcon100, password "devcon").
# Default when unset or any value other than "1": NO test users are seeded.
# MUST be unset (or removed entirely) in production.
# SEED_TEST_USERS=1
# SEED_ADMIN_PASSWORD=change_me
