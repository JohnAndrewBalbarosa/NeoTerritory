PORT=3001
CORS_ORIGIN=http://localhost:3001,http://localhost:5173
JWT_SECRET=719b60c1b3dc19c1756adde6a482568a8ee587752674d0fba0cebda169bb3f14ffe4cb4d206e7b24a63b1770b5a43863

# Mode: production | tester
# - production = real signup/signin only; /auth/test-accounts returns 404
# - tester     = clickable Devcon picker only; /auth/register returns 404
APP_MODE=production

# Tester seat count (used by tester picker UI and devcon seed)
MAX_TEST_USERS=100

# Admin always seeded with these credentials (idempotent)
ADMIN_USERNAME=Neoterritory
ADMIN_PASSWORD=ragabag123

# ROTATE THIS KEY — the old Gemini key was exposed in git history
# Set your real Anthropic key here:
ANTHROPIC_API_KEY=

# Path to the NeoTerritory C++ microservice binary and catalog
NEOTERRITORY_BIN=
NEOTERRITORY_CATALOG=

# Seed devcon1..devconN test users on boot (gated to tester mode by npm scripts)
SEED_TEST_USERS=1

GDB_RUNS_PER_WINDOW=5
GDB_COOLDOWN_MS=60000

# Per-tester Docker pod isolation. When TEST_RUNNER_USE_DOCKER=1 and
# docker is on PATH, every claimed tester seat gets its own short-lived
# container (built from docker/cpp-pod.Dockerfile). Compile + run for
# that user's GDB tests then route through docker exec instead of the
# local sandbox. Falls back to local on any failure.
TEST_RUNNER_USE_DOCKER=1
POD_IMAGE=neoterritory/cpp-pod:latest
POD_TTL_MS=600000
POD_SWEEP_MS=30000
POD_MEMORY=128m
POD_CPUS=0.25
POD_NETWORK=none
POD_PIDS_LIMIT=64