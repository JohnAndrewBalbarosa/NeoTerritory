{
  "pattern_id": "structural.adapter",
  "pattern_family": "structural",
  "pattern_name": "Adapter",
  "enabled": true,
  "lexeme_identifiers": {
    "forwarding":      ["->"],
    "wrapped_member":  ["target", "wrappee", "adaptee"]
  },
  "ordered_checks": [
    {
      "id": "class_introducer",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["class", "struct"]
    },
    {
      "id": "class_name",
      "expected_kind": "Identifier",
      "capture_as": "class_name",
      "document_as": "adapter_class"
    },
    {
      "id": "open_class_brace",
      "expected_kind": "Punctuation",
      "expected_lexeme_any_of": ["{"]
    },
    {
      "id": "wrapped_member",
      "expected_kind": "Identifier",
      "capture_as": "wrapped_member",
      "document_as": "adapter_wrapped_target"
    },
    {
      "id": "forward_operator",
      "one_of": [
        { "expected_kind": "Punctuation", "expected_lexeme_any_of": ["."] },
        { "expected_kind": "Operator",    "expected_lexeme_any_of": ["->"] }
      ],
      "document_as": "adapter_forwarding_op"
    },
    {
      "id": "forwarded_method",
      "expected_kind": "Identifier",
      "capture_as": "forwarded_method",
      "document_as": "adapter_forwarded_call"
    },
    {
      "id": "forwarded_open_paren",
      "expected_kind": "Punctuation",
      "expected_lexeme_any_of": ["("]
    }
  ],

  "implementation_template": {
    "callsites": [
      {
        "id": "wrapper_method_call",
        "shape_regex": "\\b{class_name}\\s+\\w+\\s*\\(.*\\)\\s*;[\\s\\S]{0,200}\\w+\\s*\\.\\s*\\w+\\s*\\(",
        "weight": 1.0,
        "describe": "Adapter is constructed then has a method called on it"
      }
    ],
    "expected_collaborators": [
      {
        "id": "adaptee_referenced",
        "shape_regex": "\\b{class_name}\\s*\\(\\s*\\w+\\s*\\)",
        "weight": 0.6,
        "describe": "Adapter constructed with an adaptee argument"
      }
    ],
    "global_functions": [],
    "negative_signals": [
      {
        "id": "decorator_chain_giveaway",
        "shape_regex": "\\bnew\\s+\\w+\\s*\\(\\s*new\\s+\\w+",
        "weight": -0.4,
        "describe": "Nested constructors are a Decorator giveaway, not Adapter"
      }
    ]
  },

  "ranking_weights": {
    "class_fit": 0.55,
    "implementation_fit": 0.45
  }
}
