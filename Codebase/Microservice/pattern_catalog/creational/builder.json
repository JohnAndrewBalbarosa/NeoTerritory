{
  "pattern_id": "creational.builder",
  "pattern_family": "creational",
  "pattern_name": "Builder",
  "enabled": true,
  "lexeme_identifiers": {
    "chain_return":      ["return", "*", "this", "&"],
    "setter_prefix":     ["set", "with", "add", "append", "configure", "enable",
                          "disable", "toggle", "reset", "assign", "attach", "put"],
    "terminator":        ["build", "Build", "create", "make", "construct",
                          "finalize", "done", "complete", "get", "produce", "assemble"],
    "ownership_output":  ["make_unique", "make_shared", "std::make_unique", "std::make_shared",
                          "unique_ptr", "shared_ptr", "std::unique_ptr", "std::shared_ptr",
                          "new"],
    "inner_state_types": ["std::string", "std::vector", "std::optional",
                          "std::map", "std::unordered_map", "optional", "vector"]
  },
  "ordered_checks": [
    {
      "id": "class_introducer",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["class", "struct"]
    },
    {
      "id": "class_name",
      "expected_kind": "Identifier",
      "capture_as": "class_name",
      "document_as": "builder_class"
    },
    {
      "id": "open_class_brace",
      "expected_kind": "Punctuation",
      "expected_lexeme_any_of": ["{"]
    },
    {
      "id": "fluent_return_signature",
      "expected_kind": "Operator",
      "expected_lexeme_any_of": ["&"],
      "document_as": "fluent_setter_return"
    },
    {
      "id": "fluent_return_keyword",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["return"]
    },
    {
      "id": "fluent_return_this",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["this"],
      "document_as": "fluent_self_return"
    },
    {
      "id": "build_terminator",
      "expected_kind": "Identifier",
      "expected_lexeme_any_of": ["build", "Build", "create", "make", "construct",
                                  "finalize", "done", "complete", "produce"],
      "document_as": "builder_terminator_method"
    }
  ]
}
