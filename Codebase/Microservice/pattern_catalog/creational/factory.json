{
  "pattern_id": "creational.factory",
  "pattern_family": "creational",
  "pattern_name": "Factory",
  "enabled": true,
  "ordered_checks": [
    {
      "id": "class_introducer",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["class", "struct"]
    },
    {
      "id": "class_name",
      "expected_kind": "Identifier",
      "capture_as": "class_name",
      "document_as": "factory_class"
    },
    {
      "id": "open_class_brace",
      "expected_kind": "Punctuation",
      "expected_lexeme_any_of": ["{"]
    },
    {
      "id": "branch_decision",
      "one_of": [
        { "expected_kind": "Keyword", "expected_lexeme_any_of": ["if"] },
        { "expected_kind": "Keyword", "expected_lexeme_any_of": ["switch"] }
      ],
      "document_as": "factory_branch_decision"
    },
    {
      "id": "concrete_construction",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["new"],
      "document_as": "factory_concrete_creation"
    },
    {
      "id": "return_concrete",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["return"],
      "document_as": "factory_return"
    }
  ],

  "evidence_rules": [
    { "id": "constructs_via_make_unique",  "kind": "stl_call",   "callee": "std::make_unique",   "polarity": "positive" },
    { "id": "constructs_via_make_shared",  "kind": "stl_call",   "callee": "std::make_shared",   "polarity": "positive" },
    { "id": "uses_new_keyword",            "kind": "token_pattern", "tokens": ["new"],            "polarity": "positive" },
    { "id": "branches_then_constructs",    "kind": "control_flow_then_construction", "polarity": "positive" },
    { "id": "returns_owning_pointer_to_base", "kind": "return_type_smart_ptr", "polarity": "positive" },
    { "id": "no_self_reference_return",    "kind": "self_reference_return", "polarity": "negative" }
  ]
}
