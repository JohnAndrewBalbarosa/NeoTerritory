{
  "pattern_id": "creational.singleton",
  "pattern_family": "creational",
  "pattern_name": "Singleton",
  "enabled": true,
  "ordered_checks": [
    {
      "id": "class_introducer",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["class", "struct"]
    },
    {
      "id": "class_name",
      "expected_kind": "Identifier",
      "capture_as": "class_name",
      "document_as": "singleton_class"
    },
    {
      "id": "open_class_brace",
      "expected_kind": "Punctuation",
      "expected_lexeme_any_of": ["{"]
    },
    {
      "id": "static_keyword",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["static"],
      "document_as": "static_instance_accessor"
    },
    {
      "id": "accessor_returns_reference",
      "expected_kind": "Operator",
      "expected_lexeme_any_of": ["&"]
    },
    {
      "id": "accessor_name",
      "expected_kind": "Identifier",
      "capture_as": "accessor_name",
      "document_as": "instance_accessor_method"
    },
    {
      "id": "accessor_open_paren",
      "expected_kind": "Punctuation",
      "expected_lexeme_any_of": ["("]
    },
    {
      "id": "accessor_close_paren",
      "expected_kind": "Punctuation",
      "expected_lexeme_any_of": [")"]
    },
    {
      "id": "deleted_copy_op",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["delete"],
      "document_as": "explicit_copy_deletion"
    }
  ],

  "evidence_rules": [
    { "id": "deleted_copy_ctor",            "kind": "deleted_method",  "method": "copy_ctor",       "polarity": "positive" },
    { "id": "deleted_copy_assign",          "kind": "deleted_method",  "method": "copy_assign",     "polarity": "positive" },
    { "id": "static_local_self_in_method",  "kind": "static_local",    "of_type": "{class_name}",   "polarity": "positive" },
    { "id": "static_self_member_pointer",   "kind": "static_member",   "of_type": "{class_name}",   "ptr_or_ref": true, "polarity": "positive" },
    { "id": "no_pure_virtual",              "kind": "pure_virtual_count", "max": 0, "polarity": "positive" },
    { "id": "no_self_reference_return",     "kind": "self_reference_return", "polarity": "negative" }
  ]
}
