{
  "pattern_id": "behavioural.iterator",
  "pattern_family": "behavioural",
  "pattern_name": "Iterator",
  "enabled": true,
  "signature_categories": [],
  "lexeme_identifiers": {
    "traversal_methods": ["begin", "end", "cbegin", "cend", "next", "hasNext",
                          "current", "first", "isDone", "advance"],
    "iterator_operators":["++", "*", "!=", "=="],
    "iterator_typedefs": ["iterator", "const_iterator", "Iterator"]
  },
  "ordered_checks": [
    { "id": "class_introducer", "expected_kind": "Keyword",     "expected_lexeme_any_of": ["class", "struct"] },
    { "id": "class_name",       "expected_kind": "Identifier",  "capture_as": "class_name", "document_as": "iterator_class" },
    { "id": "open_class_brace", "expected_kind": "Punctuation", "expected_lexeme_any_of": ["{"] },
    { "id": "operator_keyword", "expected_kind": "Keyword",     "expected_lexeme_any_of": ["operator"], "document_as": "iterator_operator_overload" },
    { "id": "advance_operator", "one_of": [
        { "expected_kind": "Operator",    "expected_lexeme_any_of": ["++"] },
        { "expected_kind": "Operator",    "expected_lexeme_any_of": ["*"] },
        { "expected_kind": "Punctuation", "expected_lexeme_any_of": ["*"] }
      ], "document_as": "iterator_advance_or_deref" }
  ]
}
