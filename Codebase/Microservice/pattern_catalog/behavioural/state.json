{
  "pattern_id": "behavioural.state",
  "pattern_family": "behavioural",
  "pattern_name": "State",
  "enabled": true,
  "signature_categories": [
    "interface_polymorphism"
  ],
  "lexeme_identifiers": {
    "state_methods":     ["handle", "request", "handleState", "handleInput",
                          "onEvent", "press", "push", "pull", "insertCoin",
                          "dispense", "next"],
    "context_member":    ["state", "state_", "m_state", "currentState", "current_state",
                          "currentState_"],
    "transition_call":   ["setState", "set_state", "changeState", "transitionTo",
                          "transition", "setCurrentState"],
    "virtual_interface": ["virtual", "= 0", "override", "final"]
  },
  "ordered_checks": [
    { "id": "class_introducer", "expected_kind": "Keyword",     "expected_lexeme_any_of": ["class", "struct"] },
    { "id": "class_name",       "expected_kind": "Identifier",  "capture_as": "class_name", "document_as": "state_interface_class" },
    { "id": "open_class_brace", "expected_kind": "Punctuation", "expected_lexeme_any_of": ["{"] },
    { "id": "virtual_marker",   "expected_kind": "Keyword",     "expected_lexeme_any_of": ["virtual"], "document_as": "state_virtual_marker" },
    { "id": "state_method",     "expected_kind": "Identifier",  "expected_lexeme_any_of": ["handle", "request", "handleState", "handleInput", "onEvent", "press", "insertCoin", "dispense"], "capture_as": "state_method", "document_as": "state_handle_method" },
    { "id": "open_method_paren","expected_kind": "Punctuation", "expected_lexeme_any_of": ["("] }
  ]
}
