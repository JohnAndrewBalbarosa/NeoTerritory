{
  "pattern_id": "behavioural.mediator",
  "pattern_family": "behavioural",
  "pattern_name": "Mediator",
  "enabled": true,
  "signature_categories": [
    "interface_polymorphism"
  ],
  "lexeme_identifiers": {
    "mediate_methods": ["notify", "send", "mediate", "notifyMediator", "broadcast",
                        "relay", "onComponentChanged"],
    "colleague_member":["mediator", "mediator_", "m_mediator", "colleagues", "colleagues_",
                        "participants", "components_"],
    "virtual_interface":["virtual", "= 0", "override", "final"]
  },
  "ordered_checks": [
    { "id": "class_introducer", "expected_kind": "Keyword",     "expected_lexeme_any_of": ["class", "struct"] },
    { "id": "class_name",       "expected_kind": "Identifier",  "capture_as": "class_name", "document_as": "mediator_class" },
    { "id": "open_class_brace", "expected_kind": "Punctuation", "expected_lexeme_any_of": ["{"] },
    { "id": "virtual_marker",   "expected_kind": "Keyword",     "expected_lexeme_any_of": ["virtual"], "document_as": "mediator_virtual_marker" },
    { "id": "mediate_method",   "expected_kind": "Identifier",  "expected_lexeme_any_of": ["notify", "send", "mediate", "notifyMediator", "broadcast", "relay", "onComponentChanged"], "capture_as": "mediate_method", "document_as": "mediator_notify_method" },
    { "id": "open_method_paren","expected_kind": "Punctuation", "expected_lexeme_any_of": ["("] }
  ]
}
