{
  "pattern_id": "behavioural.memento",
  "pattern_family": "behavioural",
  "pattern_name": "Memento",
  "enabled": true,
  "signature_categories": [],
  "lexeme_identifiers": {
    "memento_methods": ["save", "restore", "createMemento", "setMemento",
                        "saveState", "restoreState", "saveToMemento",
                        "restoreFromMemento", "getSnapshot", "snapshot"],
    "state_accessors": ["getState", "setState", "state", "state_", "m_state"],
    "memento_naming":  ["Memento", "Snapshot", "Originator", "Caretaker"]
  },
  "ordered_checks": [
    { "id": "class_introducer", "expected_kind": "Keyword",     "expected_lexeme_any_of": ["class", "struct"] },
    { "id": "class_name",       "expected_kind": "Identifier",  "capture_as": "class_name", "document_as": "memento_class" },
    { "id": "open_class_brace", "expected_kind": "Punctuation", "expected_lexeme_any_of": ["{"] },
    { "id": "memento_method",   "expected_kind": "Identifier",  "expected_lexeme_any_of": ["save", "restore", "createMemento", "setMemento", "saveState", "restoreState", "saveToMemento", "restoreFromMemento", "getSnapshot", "snapshot"], "capture_as": "memento_method", "document_as": "memento_save_restore_method" },
    { "id": "open_method_paren","expected_kind": "Punctuation", "expected_lexeme_any_of": ["("] }
  ]
}
