{
  "pattern_id": "behavioural.interpreter",
  "pattern_family": "behavioural",
  "pattern_name": "Interpreter",
  "enabled": true,
  "signature_categories": [
    "interface_polymorphism"
  ],
  "lexeme_identifiers": {
    "interpret_methods": ["interpret", "evaluate", "eval", "interpretExpression"],
    "context_param":     ["Context", "context", "context_"],
    "virtual_interface": ["virtual", "= 0", "override", "final"]
  },
  "ordered_checks": [
    { "id": "class_introducer", "expected_kind": "Keyword",     "expected_lexeme_any_of": ["class", "struct"] },
    { "id": "class_name",       "expected_kind": "Identifier",  "capture_as": "class_name", "document_as": "interpreter_expression_class" },
    { "id": "open_class_brace", "expected_kind": "Punctuation", "expected_lexeme_any_of": ["{"] },
    { "id": "virtual_marker",   "expected_kind": "Keyword",     "expected_lexeme_any_of": ["virtual"], "document_as": "interpreter_virtual_marker" },
    { "id": "interpret_method", "expected_kind": "Identifier",  "expected_lexeme_any_of": ["interpret", "evaluate", "eval", "interpretExpression"], "capture_as": "interpret_method", "document_as": "interpreter_interpret_method" },
    { "id": "open_method_paren","expected_kind": "Punctuation", "expected_lexeme_any_of": ["("] }
  ]
}
