{
  "pattern_id": "behavioural.command",
  "pattern_family": "behavioural",
  "pattern_name": "Command",
  "enabled": true,
  "signature_categories": [
    "interface_polymorphism"
  ],
  "lexeme_identifiers": {
    "command_methods":   ["execute", "undo", "redo", "doIt", "unexecute", "invoke", "run"],
    "receiver_member":   ["receiver", "receiver_", "m_receiver", "target", "target_",
                          "invoker", "invoker_"],
    "virtual_interface": ["virtual", "= 0", "override", "final"]
  },
  "ordered_checks": [
    { "id": "class_introducer", "expected_kind": "Keyword",     "expected_lexeme_any_of": ["class", "struct"] },
    { "id": "class_name",       "expected_kind": "Identifier",  "capture_as": "class_name", "document_as": "command_interface_class" },
    { "id": "open_class_brace", "expected_kind": "Punctuation", "expected_lexeme_any_of": ["{"] },
    { "id": "virtual_marker",   "expected_kind": "Keyword",     "expected_lexeme_any_of": ["virtual"], "document_as": "command_virtual_marker" },
    { "id": "command_method",   "expected_kind": "Identifier",  "expected_lexeme_any_of": ["execute", "undo", "redo", "doIt", "unexecute", "invoke"], "capture_as": "command_method", "document_as": "command_execute_method" },
    { "id": "open_method_paren","expected_kind": "Punctuation", "expected_lexeme_any_of": ["("] }
  ]
}
