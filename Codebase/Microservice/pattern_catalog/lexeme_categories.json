{
  "schema_version": 1,
  "description": "Connotative lexeme dictionary. Per DESIGN_DECISIONS.md D38, entries here MUST be (a) C++ keywords, (b) C++ operators/punctuation, or (c) symbols from well-known standard library APIs. Variable names and naming conventions (m_inner, getInstance, sharedInstance, build, create, cache, target, wrappee, etc.) are intentionally excluded — those are user-chosen and reading them as pattern signals is what produced the previous over-tagging. Pattern JSONs declare signature_categories (no weights) and the Round-1 ranker counts category presence.",
  "categories": {
    "object_instantiation": [
      "new",
      "make_unique",   "std::make_unique",
      "make_shared",   "std::make_shared",
      "allocate_shared", "std::allocate_shared"
    ],
    "static_storage_access": [
      "static",
      "call_once",     "std::call_once",
      "once_flag",     "std::once_flag"
    ],
    "self_return": [
      "this"
    ],
    "delegation_forward": [
      "->"
    ],
    "interface_polymorphism": [
      "virtual", "override", "final"
    ],
    "access_control_caching": [
      "mutex",            "std::mutex",
      "recursive_mutex",  "std::recursive_mutex",
      "shared_mutex",     "std::shared_mutex",
      "lock_guard",       "std::lock_guard",
      "unique_lock",      "std::unique_lock",
      "scoped_lock",      "std::scoped_lock",
      "shared_lock",      "std::shared_lock",
      "condition_variable","std::condition_variable",
      "atomic",           "std::atomic",
      "call_once",        "std::call_once"
    ],
    "ownership_handle": [
      "unique_ptr",  "std::unique_ptr",
      "shared_ptr",  "std::shared_ptr",
      "weak_ptr",    "std::weak_ptr"
    ],
    "value_comparison": [
      "==", "!=", "<", ">", "<=", ">="
    ],
    "destruction_signal": [
      "delete", "~"
    ]
  }
}
