{
  "pattern_id": "idiom.pimpl",
  "pattern_family": "idiom",
  "pattern_name": "Pimpl",
  "enabled": true,
  "lexeme_identifiers": {
    "impl_member":   ["pImpl", "impl_", "d_ptr"],
    "forward_decl":  ["class"]
  },
  "ordered_checks": [
    { "id": "class_introducer", "expected_kind": "Keyword", "expected_lexeme_any_of": ["class", "struct"] },
    { "id": "class_name", "expected_kind": "Identifier", "capture_as": "class_name", "document_as": "pimpl_outer_class" },
    { "id": "open_class_brace", "expected_kind": "Punctuation", "expected_lexeme_any_of": ["{"] },
    { "id": "inner_struct_keyword", "expected_kind": "Keyword", "expected_lexeme_any_of": ["struct"], "document_as": "pimpl_inner_struct_keyword" },
    { "id": "impl_name", "expected_kind": "Identifier", "capture_as": "impl_name", "document_as": "pimpl_impl_forward_decl" },
    { "id": "impl_semicolon", "expected_kind": "Punctuation", "expected_lexeme_any_of": [";"] },
    { "id": "smart_pointer_holder", "expected_kind": "Identifier", "expected_lexeme_any_of": ["unique_ptr", "shared_ptr"], "document_as": "pimpl_holder" }
  ],

  "implementation_template": {
    "callsites": [
      {
        "id": "pimpl_method_delegate",
        "shape_regex": "{class_name}\\s*::\\s*\\w+\\s*\\([^)]*\\)\\s*\\{[^}]{0,200}pImpl\\s*->",
        "weight": 1.0,
        "describe": "Public method delegates to pImpl-> (canonical Pimpl)"
      }
    ],
    "expected_collaborators": [
      {
        "id": "out_of_line_impl_struct",
        "shape_regex": "struct\\s+{class_name}\\s*::\\s*Impl\\s*\\{",
        "weight": 0.8,
        "describe": "Out-of-line `struct {Class}::Impl { ... }` definition"
      },
      {
        "id": "make_unique_impl_in_ctor",
        "shape_regex": "{class_name}\\s*\\([^)]*\\)\\s*:\\s*pImpl\\s*\\(\\s*(make_unique|new)\\s*<?\\s*Impl",
        "weight": 0.6,
        "describe": "Constructor initializes pImpl with make_unique<Impl>() or new Impl"
      }
    ],
    "negative_signals": []
  },

  "ranking_weights": { "class_fit": 0.45, "implementation_fit": 0.55 }
}
