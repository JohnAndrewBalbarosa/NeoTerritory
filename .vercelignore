# Vercel only builds the Vite frontend (vercel.json: cd Codebase/Frontend).
# The frontend is self-contained (tsconfig include: ["src"], no Backend imports),
# so everything else is excluded to keep the source upload small. Without this,
# the CLI tried to upload ~418MB (node_modules + .git + C++ build) and the upload
# choked.
#
# IMPORTANT: bare names use .gitignore semantics and match at ANY depth. A leading
# "/" anchors a pattern to the repo root. The root-level trees below MUST be
# anchored, otherwise e.g. "docs" also strips src/components/marketing/docs/ and
# the frontend build fails with "Cannot find module './docs/DocsPage'".

# Version control + all dependency trees (reinstalled on Vercel via installCommand)
/.git
**/node_modules

# Backend / microservice / infra — not needed to build the frontend (already
# root-anchored because they contain a slash)
Codebase/Backend
Codebase/Microservice
Codebase/Infrastructure

# Generated / heavy artifacts
Codebase/Frontend/dist
Codebase/Frontend/playwright-report
Codebase/Frontend/test-results
**/*.sqlite

# Root-level repo tooling + docs + tests not used by the frontend build.
# Leading "/" keeps these from matching same-named folders inside the frontend.
/docs
/tests
/test-artifacts
/playwright-scratch
/ops
/scripts
/supabase
/.github
/.vercel
