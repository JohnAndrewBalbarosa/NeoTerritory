!.github/workflows/
!.github/workflows/*.yml
launch.vs.json
NeoTerritory.slnx
Setup/Setup.vdproj
Codebase/Backend/keys/jwt-private.pem
# Only ignore the SQLite file inside src/db, NOT the source code that
# defines the schema. The original `/Codebase/Backend/src/db` rule
# accidentally hid initDb.ts, etlSchema.ts, etc. from new commits.
/Codebase/Backend/src/db/*.sqlite
/Codebase/Backend/src/db/*.sqlite-journal

# Test result artifacts (per-user analysis run outputs)
/test/
/Codebase/test/

# Local playwright scratch (developer-only, never commit)
/playwright-scratch/
# Playwright screenshot output (regenerated by pnpm test:e2e:screenshots).
# The spec writes to ../screenshots/ relative to testInfo.outputDir, so
# the real on-disk path is Codebase/Frontend/screenshots/. The
# pre-existing playwright/screenshots/ rule is kept for any tool that
# still drops shots there.
/Codebase/Frontend/screenshots/
/Codebase/Frontend/playwright/screenshots/
/Codebase/Frontend/playwright-report/
# Seat-state file written by all-samples.spec.ts; consumed by
# playwright/global-teardown.ts to release the tester seat even on crash.
/Codebase/Frontend/.playwright-seat.json
.claude/scheduled_tasks.lock
node_modules.stale*/
