scripts/.env.deploy
.claude/settings.local.json

# Local secrets — never commit
*.secret
aws_deploy_env.secret
# Designated drop zone for downloaded credential JSON, SSH keys, etc.
# Tracked exception: secrets/README.md so the folder stays self-documenting.
secrets/*
!secrets/README.md
# Defensive: catch downloaded Google OAuth client JSON anywhere in the
# tree, in case someone forgets to drop it into secrets/.
client_secret_*.json
client_secret_*.apps.googleusercontent.com*

# Local diagnostic probes
test-artifacts/local-unittest-*.py
test-artifacts/local-unittest-*.mjs
test-artifacts/local-unittest-*.sh
test-artifacts/soak-runs/
/test-artifacts/

# Thesis docx backups (kept locally before destructive edits — never push)
*.backup-pre-*.docx
*.backup-before-*.docx

# Thesis working materials (drafts, slides, scratch scripts).
# These are kept locally on Drew's machine but must NEVER live in the
# repo — they bloat git history with multi-MB binaries (40MB+ for a
# single _thesis_work* tree). If you need to commit a draft, put it
# under docs/thesis/ explicitly so the intent is reviewed.
/_ppt_work/
/_thesis_work/
/_thesis_work2/
/_thesis_work3/
/_thesis_work4/
# Catch-all for any future _thesis_workN/ or _ppt_workN/ at the root.
/_thesis_work*/
/_ppt_work*/

# Thesis manuscript binaries at the repo root. Anything you actually
# want versioned belongs in docs/ with a real path.
/FINAL THESIS 3 PAPER.docx
/FINAL THESIS 3 PAPER.pdf
/FINAL-THESIS-3-PAPER-1 (2).docx
/CS-THESIS DOCUMENT -CHAPTER 4 TO 5.docx
/THESIS 3 DEFENSE- PPT CONTENT.docx
/CodiNeo - Thesis 3 Defense.pptx
/NOTES-FOR-DOCS-WRITER.txt
/cody_codineo_mascot_transparent.svg
# Catch root-level docx/pptx/pdf so future scratch drafts don't slip
# in. Anything under docs/ remains tracked since the rules are root-anchored.
/*.docx
/*.pdf
/*.pptx

# One-shot scratch scripts at the repo root.
/mobile-audit-tmp.mjs

# Probe scripts inside test-artifacts/ that aren't named with the
# existing local-unittest-* prefix.
test-artifacts/local-stream-probe.py
test-artifacts/probe-pod-*.sh

# Timestamped regression sweep artifacts (regenerated by tools/thesis-sim).
test-artifacts/regression-sweep-*.json
test-artifacts/learning-audit/out-builder-*/

# Thesis-simulation tooling — local-only dataset shaping, seed scripts,
# and reseed wrappers. All artifacts here are derived data + local
# experimentation; not part of the shipped product surface.
tools/thesis-sim/

