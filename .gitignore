# Local environment and runtime logs
.env
.env.*
!.env.example
!.env.deploy.example
scripts/.env.deploy

# Local secrets — never commit
*.secret
aws_deploy_env.secret
# Designated drop zone for downloaded credential JSON, SSH keys, etc.
# Tracked exception: secrets/README.md so the folder stays self-documenting.
secrets/*
!secrets/README.md
# Defensive: catch downloaded Google OAuth client JSON anywhere in the
# tree, in case someone forgets to drop it into secrets/.
client_secret_*.json
client_secret_*.apps.googleusercontent.com*

# Local diagnostic probes
test-artifacts/local-unittest-*.py
test-artifacts/local-unittest-*.mjs
test-artifacts/local-unittest-*.sh
test-artifacts/soak-runs/

# Thesis docx backups (kept locally before destructive edits — never push)
*.backup-pre-*.docx
*.backup-before-*.docx

# SSH / deploy credentials — never commit, even locally
*.pem
*.key
*.ppk
*.pfx
*.p12
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*
known_hosts
authorized_keys
.ssh/
**/.ssh/

# Local keys and credentials
Codebase/Backend/keys/

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

