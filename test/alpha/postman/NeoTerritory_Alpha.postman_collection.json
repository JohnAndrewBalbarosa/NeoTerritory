{
  "info": {
    "name": "NeoTerritory Alpha — Connection & SLA",
    "_postman_id": "a3f12c44-8b21-4d19-bb9b-2c9c3a4b1d01",
    "description": "Alpha-phase connection tests with hard SLA gates. Each request validates: (1) 2xx status, (2) JSON contract shape, (3) latency under environment threshold (RAIL / ITU-T G.1010 / Nielsen). Designed to be CI-runnable via Newman.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "jwt", "value": "" },
    { "key": "pendingId", "value": "" },
    { "key": "runId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{jwt}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global pre-request: shared SLA helper.",
          "// Using p95 thresholds from environment so a single collection runs against",
          "// both Local and Deploy. Reference: Google RAIL, ITU-T G.1010, Nielsen 0.1/1/10s.",
          "pm.globals.set('assertSla', `",
          "(function(label, budgetMs){",
          "  pm.test('[' + label + '] latency <= ' + budgetMs + ' ms (was ' + pm.response.responseTime + ' ms)', function(){",
          "    pm.expect(pm.response.responseTime).to.be.below(budgetMs + 1);",
          "  });",
          "})",
          "`);"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01 Connection",
      "item": [
        {
          "name": "GET /health (liveness)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type JSON', () => pm.response.to.be.json);",
                  "const body = pm.response.json();",
                  "pm.test('status field present', () => pm.expect(body.status).to.be.a('string'));",
                  "eval(pm.globals.get('assertSla'))('GET /health', Number(pm.environment.get('slaHealthMs')));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api (service descriptor)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api", "host": ["{{baseUrl}}"], "path": ["api"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('endpoints array', () => pm.expect(body.endpoints).to.be.an('array').that.is.not.empty);",
                  "eval(pm.globals.get('assertSla'))('GET /api', Number(pm.environment.get('slaHealthMs')));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/health (deep health)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api", "health"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('microservice descriptor present', () => {",
                  "  pm.expect(body.microservice).to.be.an('object');",
                  "  pm.expect(body.microservice).to.have.property('binaryFound');",
                  "  pm.expect(body.microservice).to.have.property('catalogFound');",
                  "});",
                  "pm.test('microservice binary + catalog discoverable', () => {",
                  "  pm.expect(body.microservice.binaryFound, 'binaryFound').to.equal(true);",
                  "  pm.expect(body.microservice.catalogFound, 'catalogFound').to.equal(true);",
                  "});",
                  "eval(pm.globals.get('assertSla'))('GET /api/health', Number(pm.environment.get('slaApiHealthMs')));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 Auth",
      "item": [
        {
          "name": "GET /auth/test-accounts (alpha seed)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/test-accounts", "host": ["{{baseUrl}}"], "path": ["auth", "test-accounts"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('accounts is array', () => pm.expect(b.accounts).to.be.an('array'));",
                  "if (b.accounts.length) {",
                  "  pm.environment.set('seedUsername', b.accounts[0].username || b.accounts[0]);",
                  "  pm.environment.set('seedPassword', b.password || 'devcon');",
                  "}",
                  "eval(pm.globals.get('assertSla'))('GET /auth/test-accounts', Number(pm.environment.get('slaHealthMs')));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{seedUsername}}\",\n  \"password\": \"{{seedPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('JWT issued', () => pm.expect(b.token, 'token').to.be.a('string').and.have.length.above(20));",
                  "pm.collectionVariables.set('jwt', b.token);",
                  "eval(pm.globals.get('assertSla'))('POST /auth/login', Number(pm.environment.get('slaLoginMs')));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 Analysis Pipeline",
      "item": [
        {
          "name": "GET /api/analyze/sample",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/analyze/sample", "host": ["{{baseUrl}}"], "path": ["api", "analyze", "sample"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('sample code present', () => pm.expect(b.code).to.be.a('string').and.have.length.above(10));",
                  "pm.environment.set('sampleCode', b.code);",
                  "pm.environment.set('sampleFilename', b.filename || 'sample.cpp');",
                  "eval(pm.globals.get('assertSla'))('GET /api/analyze/sample', Number(pm.environment.get('slaHealthMs')));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/analyze (small cpp)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{jwt}}", "type": "string" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filename\": \"{{sampleFilename}}\",\n  \"code\": {{sampleCodeJson}}\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/analyze", "host": ["{{baseUrl}}"], "path": ["api", "analyze"] }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Encode the sample code as a JSON string for the request body.",
                  "const code = pm.environment.get('sampleCode') || 'class A {};';",
                  "pm.environment.set('sampleCodeJson', JSON.stringify(code));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('pendingId returned', () => pm.expect(b.pendingId).to.be.a('string'));",
                  "pm.test('pipeline array present', () => pm.expect(b.pipeline).to.be.an('array').that.is.not.empty);",
                  "pm.test('detectedPatterns is array', () => pm.expect(b.detectedPatterns).to.be.an('array'));",
                  "pm.test('annotations is array', () => pm.expect(b.annotations).to.be.an('array'));",
                  "pm.collectionVariables.set('pendingId', b.pendingId);",
                  "// p95-style ceiling per request (single-shot). Stress harness measures the real p95.",
                  "eval(pm.globals.get('assertSla'))('POST /api/analyze', Number(pm.environment.get('slaAnalyzeMs')));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/runs/save",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{jwt}}", "type": "string" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pendingId\": \"{{pendingId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/runs/save", "host": ["{{baseUrl}}"], "path": ["api", "runs", "save"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const b = pm.response.json();",
                  "pm.test('runId issued', () => pm.expect(b.runId).to.be.a('number'));",
                  "pm.collectionVariables.set('runId', b.runId);",
                  "eval(pm.globals.get('assertSla'))('POST /api/runs/save', Number(pm.environment.get('slaApiHealthMs')));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/runs/:id",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{jwt}}", "type": "string" }]
            },
            "url": {
              "raw": "{{baseUrl}}/api/runs/{{runId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "runs", "{{runId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('analysis present', () => pm.expect(b.analysis).to.be.an('object'));",
                  "pm.test('annotations is array', () => pm.expect(b.analysis.annotations).to.be.an('array'));",
                  "eval(pm.globals.get('assertSla'))('GET /api/runs/:id', Number(pm.environment.get('slaApiHealthMs')));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04 Negative / Contract",
      "item": [
        {
          "name": "POST /api/analyze without auth -> 401",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"code\":\"class X{};\"}" },
            "url": { "raw": "{{baseUrl}}/api/analyze", "host": ["{{baseUrl}}"], "path": ["api", "analyze"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('401 Unauthorized', () => pm.response.to.have.status(401));",
                  "eval(pm.globals.get('assertSla'))('POST /api/analyze (no auth)', Number(pm.environment.get('slaHealthMs')));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/analyze with empty body -> 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{jwt}}", "type": "string" }]
            },
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{baseUrl}}/api/analyze", "host": ["{{baseUrl}}"], "path": ["api", "analyze"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('400 Bad Request', () => pm.response.to.have.status(400));",
                  "eval(pm.globals.get('assertSla'))('POST /api/analyze (empty)', Number(pm.environment.get('slaHealthMs')));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
